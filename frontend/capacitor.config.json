{
  "appId": "com.vietsat.app",
  "appName": "TiemNhaDuy",
  "webDir": "dist",
  "bundledWebRuntime": false,
  "npmClient": "npm",
  "cordova": {
    "preferences": {
      "ScrollEnabled": "true",
      "Orientation": "portrait",
      "StatusBarOverlaysWebView": "false",
      "StatusBarBackgroundColor": "#000000"
    }
  },
  "ios": {
    "xcodeVersion": "15.0",
    "cordovaLinkerFlags": ["-ObjC"]
  },
  "android": {
    "minSdkVersion": 22,
    "targetSdkVersion": "34"
  }
}
