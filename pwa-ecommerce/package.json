{
    "$schema": "https://json.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "esbuild:build": "esbuild resources/js/app.js --bundle --minify --sourcemap --outfile=public/js/main.js && esbuild resources/css/app.css --bundle --minify --outfile=public/css/main.css",
        "esbuild:watch": "esbuild resources/js/app.js --bundle --outfile=public/js/main.js --watch & esbuild resources/css/app.css --bundle --outfile=public/css/main.css --watch"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.0.0",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "esbuild": "^0.18.17",
        "laravel-echo": "^2.3.0",
        "laravel-vite-plugin": "^2.0.0",
        "pusher-js": "^8.4.0",
        "tailwindcss": "^4.0.0",
        "vite": "^7.0.4"
    }
}
